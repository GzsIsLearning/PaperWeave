# Paperweave Environment Configuration
# Copy this file to .env and fill in your values

# Path to the paperweave-v1 project directory
PAPERWEAVE_ROOT=/path/to/paperweave

# DeepSeek API (LLM provider)
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM settings
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3

# Agent settings
AGENT_CMD=hermes
AGENT_TIMEOUT=120

# API server port
PAPERWEAVE_PORT=8899

# Optional: API auth token (if unset, no auth required)
# PAPERWEAVE_AUTH_TOKEN=your-secret-token

# MinerU API (PDF extraction)
MINERU_TOKEN=your-mineru-token
